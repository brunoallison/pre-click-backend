NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Banco (dev: docker-compose | prod: Cloud SQL via Auth Proxy → 127.0.0.1)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USERNAME=pedido
POSTGRES_PASSWORD=pedido
POSTGRES_DATABASE=pedido
POSTGRES_SCHEMA=public

# Redis (TLS desativado em dev; ativar em prod)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Auth
JWT_SECRET=dev-secret-min-16chars
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google Cloud Storage
# ADC: rode 'gcloud auth application-default login' localmente
# Cloud Run usa a SA do container automaticamente
GCS_BUCKET_NAME=pedido-dev-uploads
GCP_PROJECT_ID=
CLOUD_SQL_CONNECTION_NAME=

# Fake GCS local (apenas para testes de integração — ver docker-compose)
# Não setar em prod; usar GCS real

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Datadog (apenas em prod; não setar localmente)
DD_ENV=
DD_SERVICE=pedido-api
DD_VERSION=
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_URL=unix:///opt/datadog-agent/run/apm.socket
DD_LOGS_INJECTION=false
DD_API_KEY=
DD_SITE=datadoghq.com
LOG_FILE=

# CORS
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
